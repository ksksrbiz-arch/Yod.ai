{
  "name": "openyoda",
  "version": "0.2.0",
  "private": true,
  "description": "Yoda.ai — premium AI wisdom platform. Monorepo for the web app, bots, extensions, CLI, agent runtime, SDKs, and shared packages.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=20"
  }
}
