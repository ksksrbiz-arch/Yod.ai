{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" },
        "rank": { "type": "string", "enum": ["youngling", "padawan", "knight", "master"] }
      },
      "required": ["email", "createdAt", "rank"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message stored in the holocron",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model", "action"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile document"
    },
    "users/{userId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages sent by or to the user"
    }
  }
}
